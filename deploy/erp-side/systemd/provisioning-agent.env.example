# Copy to /etc/provisioning-agent/environment (mode 640, root-owned or dedicated ops user)
# Use real secrets; do not commit populated files.
#
# Docs: provisioning-agent/docs/erp-side-runbook.md

NODE_ENV=production
PORT=8080
PROVISIONING_API_TOKEN=replace-with-long-random-token-matching-control-plane
ERP_ADMIN_PASSWORD=replace-with-erp-admin-password
ERP_EXECUTION_BACKEND=docker
ERP_BENCH_PATH=/home/frappe/frappe-bench
ERP_BENCH_EXECUTABLE=bench
ERP_BASE_DOMAIN=erp.example.com
ERP_API_USERNAME_PREFIX=cp
ERP_COMMAND_TIMEOUT_MS=120000
# Required when ERP_EXECUTION_BACKEND=docker:
# ERP_CONTAINER_NAME=your-erp-backend-container
# Required when ERP_EXECUTION_BACKEND=remote:
# ERP_REMOTE_BASE_URL=http://127.0.0.1:8081
# ERP_REMOTE_TOKEN=replace-with-remote-shared-token
# ERP_REMOTE_TIMEOUT_MS=15000
