# Schema for runtime configuration (see `src/config/env.ts`).
#
# Local development:
#   Copy to `.env` (gitignored) and adjust values. Docker Compose and `npm` can load it.
#
# Production (Dokploy):
#   Do not rely on a committed or server-side `.env` file for secrets. Define every variable
#   in Dokploy → Environment for this service. After changing env there, redeploy so containers
#   pick up the new values.

# Node environment: development | test | production
NODE_ENV=development

# HTTP listen port inside the container (must match healthcheck / published port mapping)
PORT=8080

# Bearer token for the provisioning HTTP API (minimum 16 characters)
PROVISIONING_API_TOKEN=development-placeholder-token-min-16-chars

# Base URL of the remote ERP execution API (required by the app schema)
ERP_REMOTE_BASE_URL=http://127.0.0.1:9000/

# Bearer or shared secret for the remote ERP execution API (required)
ERP_REMOTE_TOKEN=development-remote-token

# HTTP client timeout in milliseconds for remote ERP calls
ERP_REMOTE_TIMEOUT_MS=15000

# ERP tenant base domain used when building hostnames
ERP_BASE_DOMAIN=erp.zaidan-group.com

# Prefix for ERP API usernames created by the agent
ERP_API_USERNAME_PREFIX=cp
