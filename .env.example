# Copy to `.env` and set values (or inject via your orchestrator).
# Required / supported variables (see `src/config/env.ts`):
#
# NODE_ENV=development
# PORT=8080
# PROVISIONING_API_TOKEN=
# ERP_EXECUTION_BACKEND=docker
# ERP_REMOTE_BASE_URL=
# ERP_REMOTE_TOKEN=
# ERP_REMOTE_TIMEOUT_MS=15000
# ERP_BASE_DOMAIN=
# ERP_API_USERNAME_PREFIX=cp
# ERP_COMMAND_TIMEOUT_MS=120000

# This file is intentionally empty of secrets.
# All environment variables can be injected at deploy time (e.g. Dokploy UI Environment tab).
