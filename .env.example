NODE_ENV=development
PORT=8080
PROVISIONING_API_TOKEN=change-me-super-long-random-token
ERP_ADMIN_PASSWORD=change-me-strong-erp-admin-password

# --- Phase 1 (Control Plane -> provisioning-agent -> erp-execution-service) ---
# Required to run the HTTP server (or use ERP_REMOTE_BASE_URL + ERP_REMOTE_TOKEN instead):
ERP_EXECUTION_BASE_URL=http://erp-execution-service:8081
ERP_EXECUTION_TOKEN=change-me-shared-bearer-for-erp-execution-service
ERP_EXECUTION_TIMEOUT_MS=15000

ERP_BENCH_PATH=/home/frappe/frappe-bench
# development/test: defaults to docker when unset. production: defaults to remote when unset.
# Explicit values: docker (dev/test bridge; needs Docker CLI on host) | remote (production)
ERP_EXECUTION_BACKEND=docker
ERP_BENCH_EXECUTABLE=bench
ERP_CONTAINER_NAME=axiserp-erpnext-pnzjyk-backend-1
ERP_BASE_DOMAIN=erp.zaidan-group.com
ERP_API_USERNAME_PREFIX=cp
ERP_COMMAND_TIMEOUT_MS=120000
# Backward-compatible aliases (optional if ERP_EXECUTION_* are set):
# ERP_REMOTE_BASE_URL=https://erp-executor.internal:8081
# ERP_REMOTE_TOKEN=change-me-remote-shared-token
# ERP_REMOTE_TIMEOUT_MS=15000
# Required when ERP_EXECUTION_BACKEND=docker AND NODE_ENV=production:
# ERP_DOCKER_ALLOW_IN_PRODUCTION=true
# Optional: probe ERP backend on GET /health/ready
# ERP_HEALTH_CHECK_DOWNSTREAM=true
